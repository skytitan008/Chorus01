---
import { t, tRaw } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const showcaseItems = tRaw(lang, 'showcase.items') as Array<{ title: string; description: string }>;

const itemMeta = [
  { src: "/images/pixcel-workspace.gif", alt: "Pixel Workspace", wide: true },
  { src: "/images/kanban-auto-update.gif", alt: "Kanban Auto Update", wide: true },
  { src: "/images/dag.png", alt: "Task DAG", wide: false },
  { src: "/images/elaboration.png", alt: "Requirements Elaboration", wide: false },
  { src: "/images/proposal.png", alt: "Proposal Review", wide: false },
  { src: "/images/task-tracking.png", alt: "Task Tracking", wide: false },
];

const items = showcaseItems.map((item, i) => ({
  ...itemMeta[i],
  title: item.title,
  description: item.description,
}));
---

<section class="section" id="showcase">
  <div class="section-header">
    <div class="section-label">{t(lang, 'showcase.label')}</div>
    <h2>{t(lang, 'showcase.title')}</h2>
    <p>{t(lang, 'showcase.subtitle')}</p>
  </div>
  <div class="showcase-grid">
    {items.map((item) => (
      <div class:list={["showcase-item", { wide: item.wide }]}>
        <img src={item.src} alt={item.alt} loading="lazy" />
        <div class="showcase-caption">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .showcase-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.25s;
  }
  .showcase-item:hover {
    border-color: var(--primary-light);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.06);
  }
  .showcase-item.wide {
    grid-column: 1 / -1;
  }
  .showcase-item img {
    width: 100%;
    display: block;
  }
  .showcase-caption {
    padding: 20px 24px;
  }
  .showcase-caption h3 {
    font-size: 16px; font-weight: 700;
    margin-bottom: 6px;
  }
  .showcase-caption p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .showcase-grid { grid-template-columns: 1fr; }
    .showcase-item.wide { grid-column: auto; }
  }
</style>
