---
import { t, langPrefix, getAlternateUrl } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const pre = langPrefix(lang);
const githubUrl = "https://github.com/Chorus-AIDLC/chorus";
const dockerUrl = "https://hub.docker.com/repository/docker/chorusaidlc/chorus-app/general";
const altUrl = getAlternateUrl(Astro.url);
const currentLabel = lang === 'en' ? 'EN' : '中文';
const altLabel = lang === 'en' ? '中文' : 'EN';
---

<nav>
  <div class="nav-inner">
    <a href={`${pre}/`} class="logo">
      <img src="/images/chorus-icon.png" alt="Chorus" />
      Chorus<span>.</span>
    </a>
    <div class="nav-links">
      <a href={`${pre}/#features`}>{t(lang, 'nav.features')}</a>
      <a href={`${pre}/#showcase`}>{t(lang, 'nav.showcase')}</a>
      <a href={`${pre}/#agents`}>{t(lang, 'nav.agents')}</a>
      <a href={`${pre}/blog/`}>{t(lang, 'nav.blog')}</a>
    </div>
    <div class="nav-actions">
      <!-- Language dropdown -->
      <div class="lang-dropdown" id="lang-dropdown">
        <button class="lang-trigger" id="lang-trigger" aria-label="Language">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          <span>{currentLabel}</span>
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="lang-menu" id="lang-menu">
          <a href={`${pre}/`} class:list={["lang-option", { active: lang === 'en' }]}>English</a>
          <a href={altUrl} class:list={["lang-option", { active: lang === 'zh' }]}>中文</a>
        </div>
      </div>
      <a href={dockerUrl} class="nav-icon-link" title={t(lang, 'nav.dockerHub')} aria-label={t(lang, 'nav.dockerHub')} target="_blank" rel="noopener noreferrer">
        <svg width="24" height="19" viewBox="0 0 24 19" fill="currentColor"><path d="M13.98 11.08h2.12a.19.19 0 00.19-.18V9.01a.19.19 0 00-.19-.19h-2.12a.19.19 0 00-.18.19v1.89c0 .1.08.18.18.18zm-2.95 0h2.12a.19.19 0 00.19-.18V9.01a.19.19 0 00-.19-.19h-2.12a.19.19 0 00-.19.19v1.89c0 .1.09.18.19.18zm-2.93 0h2.12a.19.19 0 00.18-.18V9.01a.19.19 0 00-.18-.19H8.1a.19.19 0 00-.19.19v1.89c0 .1.09.18.19.18zm-2.96 0h2.12a.19.19 0 00.19-.18V9.01a.19.19 0 00-.19-.19H5.14a.19.19 0 00-.18.19v1.89c0 .1.08.18.18.18zm5.89-2.8h2.12a.19.19 0 00.19-.19V6.2a.19.19 0 00-.19-.19h-2.12a.19.19 0 00-.18.19v1.89c0 .1.08.19.18.19zm-2.93 0h2.12a.19.19 0 00.18-.19V6.2a.19.19 0 00-.18-.19H8.1a.19.19 0 00-.19.19v1.89c0 .1.09.19.19.19zm-2.96 0h2.12a.19.19 0 00.19-.19V6.2a.19.19 0 00-.19-.19H5.14a.19.19 0 00-.18.19v1.89c0 .1.08.19.18.19zM8.1 5.47h2.12a.19.19 0 00.18-.19V3.39a.19.19 0 00-.18-.18H8.1a.19.19 0 00-.19.18v1.89c0 .1.09.19.19.19zm13.74 3.57c-.58-.3-1.21-.4-1.79-.34-.2-1.3-1.2-2.43-2.32-3.09l-.46-.27-.3.44c-.37.58-.58 1.24-.52 1.93.02.26.09.73.38 1.15-.27.15-.79.36-1.48.34H.36l-.11.6a9.6 9.6 0 00.8 4.8l.03.05c.56.96 1.38 1.7 2.4 2.18 1.2.56 2.24.82 3.47.82 1.33 0 2.42-.16 3.44-.5a9.3 9.3 0 002.7-1.54c.9-.78 1.7-1.71 2.36-2.86.52-.9.94-1.91 1.18-3.04h.34c.99 0 1.8-.33 2.33-.82.29-.27.5-.6.58-.96l.08-.32-.27-.16z"/></svg>
      </a>
      <a href={githubUrl} class="nav-github" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span class="gh-label">GitHub</span>
        <span class="gh-stars" id="gh-stars">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="opacity:0.7"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
      </a>
      <!-- Mobile hamburger -->
      <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
        <svg class="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
  <!-- Mobile dropdown -->
  <div class="mobile-menu" id="mobile-menu">
    <a href={`${pre}/#features`}>{t(lang, 'nav.features')}</a>
    <a href={`${pre}/#showcase`}>{t(lang, 'nav.showcase')}</a>
    <a href={`${pre}/#agents`}>{t(lang, 'nav.agents')}</a>
    <a href={`${pre}/blog/`}>{t(lang, 'nav.blog')}</a>
    <div class="mobile-divider"></div>
    <div class="mobile-lang">
      <a href="/" class:list={[{ active: lang === 'en' }]}>English</a>
      <a href="/zh/" class:list={[{ active: lang === 'zh' }]}>中文</a>
    </div>
    <div class="mobile-divider"></div>
    <div class="mobile-actions">
      <a href={dockerUrl} target="_blank" rel="noopener noreferrer">{t(lang, 'nav.dockerHub')}</a>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer">{t(lang, 'nav.github')}</a>
    </div>
  </div>
</nav>

<script>
  async function fetchStars() {
    const el = document.getElementById('gh-stars');
    if (!el) return;
    try {
      const res = await fetch('https://api.github.com/repos/Chorus-AIDLC/chorus');
      if (!res.ok) return;
      const data = await res.json();
      const count = data.stargazers_count;
      if (typeof count === 'number') {
        const label = count >= 1000 ? (count / 1000).toFixed(1) + 'k' : String(count);
        el.insertAdjacentHTML('beforeend', `<span>${label}</span>`);
      }
    } catch { /* silent */ }
  }
  fetchStars();

  // Mobile menu
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      toggle.classList.toggle('active', open);
    });
    menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        menu.classList.remove('open');
        toggle.classList.remove('active');
      });
    });
  }

  // Language dropdown
  const langTrigger = document.getElementById('lang-trigger');
  const langMenu = document.getElementById('lang-menu');
  if (langTrigger && langMenu) {
    langTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      langMenu.classList.toggle('open');
    });
    document.addEventListener('click', () => langMenu.classList.remove('open'));
  }

  // Save language choice to localStorage
  document.querySelectorAll('.lang-option, .mobile-lang a').forEach(a => {
    a.addEventListener('click', () => {
      const href = (a as HTMLAnchorElement).getAttribute('href') || '';
      const lang = href.startsWith('/zh') ? 'zh' : 'en';
      localStorage.setItem('chorus-lang', lang);
    });
  });
</script>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(250, 248, 244, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 0 32px;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .logo {
    font-size: 22px; font-weight: 800;
    color: var(--primary);
    letter-spacing: -0.5px;
    text-decoration: none;
    display: flex; align-items: center; gap: 10px;
    flex-shrink: 0;
  }
  .logo img { width: 32px; height: 32px; }
  .logo span { color: var(--text-primary); }

  .nav-links {
    display: flex; gap: 28px; align-items: center;
  }
  .nav-links a {
    font-size: 14px; font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-links a:hover { color: var(--text-primary); }

  .nav-actions {
    display: flex; align-items: center; gap: 10px;
    flex-shrink: 0;
  }

  /* Language dropdown */
  .lang-dropdown { position: relative; }
  .lang-trigger {
    display: flex; align-items: center; gap: 5px;
    padding: 6px 10px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    transition: all 0.2s;
  }
  .lang-trigger:hover { border-color: var(--primary); color: var(--primary); }
  .lang-trigger .chevron { transition: transform 0.2s; }
  .lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 120px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    padding: 4px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.2s;
  }
  .lang-menu.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .lang-option {
    display: block;
    padding: 8px 14px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 7px;
    transition: all 0.15s;
  }
  .lang-option:hover { background: rgba(198,122,82,0.08); color: var(--text-primary); }
  .lang-option.active { color: var(--primary); font-weight: 600; }

  .nav-icon-link {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px;
    border-radius: 8px;
    color: var(--text-secondary);
    transition: all 0.2s;
    text-decoration: none;
  }
  .nav-icon-link:hover {
    color: var(--primary);
    background: rgba(198,122,82,0.08);
  }
  .nav-github {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 7px 16px;
    font-size: 14px; font-weight: 600;
    color: #fff;
    background: var(--text-primary);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-github:hover {
    background: #444;
    transform: translateY(-1px);
  }
  .gh-stars {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-left: 2px;
    padding-left: 8px;
    border-left: 1px solid rgba(255,255,255,0.15);
    font-size: 13px;
    font-weight: 500;
  }

  /* Hamburger */
  .menu-toggle {
    display: none;
    width: 40px; height: 40px;
    border: none; background: none;
    cursor: pointer;
    color: var(--text-primary);
    padding: 0;
    align-items: center; justify-content: center;
  }
  .menu-toggle .icon-close { display: none; }
  .menu-toggle.active .icon-open { display: none; }
  .menu-toggle.active .icon-close { display: block; }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 8px 32px 20px;
    background: rgba(250, 248, 244, 0.98);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .mobile-menu a {
    display: block;
    padding: 12px 0;
    font-size: 15px; font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .mobile-menu a:last-child { border-bottom: none; }
  .mobile-divider { height: 1px; background: var(--border); margin: 4px 0; }
  .mobile-lang {
    display: flex; gap: 8px; padding: 8px 0;
  }
  .mobile-lang a {
    flex: 1; text-align: center;
    padding: 8px; border-radius: 8px;
    font-size: 14px; font-weight: 600;
    border: 1px solid var(--border);
    color: var(--text-secondary);
  }
  .mobile-lang a.active {
    background: rgba(198,122,82,0.1);
    border-color: var(--primary);
    color: var(--primary);
  }
  .mobile-actions { display: flex; gap: 12px; padding-top: 8px; }
  .mobile-actions a {
    flex: 1; text-align: center;
    padding: 10px; border-radius: 8px;
    font-size: 14px; font-weight: 600;
    border-bottom: none;
  }
  .mobile-actions a:first-child {
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-primary);
  }
  .mobile-actions a:last-child {
    background: var(--text-primary);
    color: #fff;
  }

  @media (max-width: 768px) {
    .nav-links { gap: 20px; }
  }
  @media (max-width: 600px) {
    .nav-inner { padding: 0 20px; }
    .nav-links { display: none; }
    .nav-icon-link { display: none; }
    .lang-dropdown { display: none; }
    .gh-label, .gh-stars { display: none; }
    .nav-github { padding: 7px 10px; }
    .menu-toggle { display: flex; }
    .mobile-menu.open { display: flex; }
  }
</style>
